{
    "name": "s3tech/laravel-auth-kit",
    "description": "Package Laravel plug-and-play : auth Sanctum, OTP reset, rôles Spatie, logs d'activité.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "auth", "sanctum", "otp", "roles", "permissions", "activity-log"],
    "authors": [
        {
            "name": "3S Tech Group",
            "email": "contact@3stechgroup.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "laravel/framework": "^10.0|^11.0",
        "laravel/sanctum": "^3.0|^4.0",
        "spatie/laravel-permission": "^6.0",
        "stevebauman/location": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "S3Tech\AuthKit\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "S3Tech\AuthKit\\AuthKitServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
